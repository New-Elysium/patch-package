{
  "name": "@psync/patch-package",
  "version": "1.0.0",
  "description": "Fix broken node modules with no fuss",
  "main": "dist/index.js",
  "repository": "github:New-Elysium/patch-package",
  "author": "David Sheldrick",
  "license": "MIT",
  "engines": {
    "node": ">=14",
    "npm": ">5",
    "bun": ">=1.3.14"
  },
  "bin": {
    "patch-package": "./index.js"
  },
  "scripts": {
    "prepublishOnly": "bun run clean && bun run build",
    "build": "tsc --project tsconfig.build.json",
    "new-integration-test": "bun run integration-tests/newIntegrationTest.ts",
    "clean": "rimraf dist",
    "format": "prettier --no-semi --write --trailing-comma=all \"src{/**,}/*.ts\" \"integration-tests{/**,}/*.ts\" \"property-based-tests{/**,}/*.ts\"",
    "prepack": "node -e \"var f=require('fs'),p=require('path');function r(d){f.readdirSync(d,{withFileTypes:true}).forEach(e=>{var fp=p.join(d,e.name);if(e.isDirectory())r(fp);else if(e.name.match(/\\.test\\./))f.unlinkSync(fp)})};r('dist')\"",
    "test": "./run-tests.sh --runInBand",
    "test:unit": "jest --testPathPatterns=src/",
    "typecheck": "tsc --noEmit --project tsconfig.build.json"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --no-semi --trailing-comma=all --check"
    ]
  },
  "jest": {
    "testRegex": "/(src|integration-tests|property-based-tests)/.+\\.test\\.ts$",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "diagnostics": false
        }
      ]
    }
  },
  "devDependencies": {
    "@types/app-root-path": "^3.1.0",
    "@types/cross-spawn": "^6.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/json-stable-stringify": "^1.2.0",
    "@types/klaw-sync": "^6.0.5",
    "@types/minimist": "^1.2.5",
    "@types/node": "^22.10.0",
    "@types/randomstring": "^1.3.0",
    "@types/rimraf": "^4.0.5",
    "@types/semver": "^7.7.1",
    "@types/slash": "ts2.0",
    "@types/tmp": "^0.2.6",
    "@types/yarnpkg__lockfile": "^1.1.9",
    "jest": "^30.0.0",
    "lint-staged": "^17.0.0",
    "prettier": "^3.0.0",
    "randomstring": "^1.3.0",
    "rimraf": "^6.0.0",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.0",
    "tslib": "^2.8.0",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "@yarnpkg/lockfile": "^1.1.0",
    "chalk": "^4.1.2",
    "ci-info": "^3.7.0",
    "cross-spawn": "^7.0.3",
    "find-yarn-workspace-root": "^2.0.0",
    "fs-extra": "^10.0.0",
    "json-stable-stringify": "^1.0.2",
    "klaw-sync": "^6.0.0",
    "minimist": "^1.2.6",
    "open": "^7.4.2",
    "semver": "^7.5.3",
    "slash": "^2.0.0",
    "tmp": "^0.2.4",
    "yaml": "^2.2.2"
  },
  "files": [
    "index.js",
    "dist/**/*.js",
    "CHANGELOG.md",
    "LICENSE",
    "patch-package-banner.png",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "bun@1.3.14"
}
